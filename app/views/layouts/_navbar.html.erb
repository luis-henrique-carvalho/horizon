<div class="navbar bg-base-100 shadow-sm">
  <%# Logo / Brand %>
  <div class="flex-1">
    <%= link_to root_path, class: "btn btn-ghost text-xl" do %>
      Horizon
    <% end %>
  </div>

  <%# Right side %>
  <div class="flex items-center gap-2">
    <% if user_signed_in? %>
      <%# Avatar dropdown %>
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar placeholder">
          <div class="bg-neutral text-neutral-content w-10 rounded-full">
            <span><%= current_user.email.first.upcase %></span>
          </div>
        </div>
        <ul tabindex="-1" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-10 mt-3 w-52 p-2 shadow">
          <%# mostrar somente primeira parte do email antes do @ %>
          <li class="menu-title"><%= current_user.email.split('@').first %></li>
          <li><%= link_to "Objetivos", goals_path %></li>
          <li><%= link_to "Sair", destroy_user_session_path, data: { turbo_method: :delete } %></li>
        </ul>
      </div>
    <% else %>
      <%= link_to "Entrar", new_user_session_path, class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</div>
