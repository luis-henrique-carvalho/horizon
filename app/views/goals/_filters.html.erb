<%= form_with url: goals_path, method: :get, class: "flex flex-wrap items-center gap-4 w-full" do |f| %>
  <%= f.hidden_field :tab, value: params[:tab] %>

  <div class="flex flex-col lg:flex-row gap-4 w-full lg:w-auto">
    <%# Search Input %>
    <div class="flex-1 lg:flex-none min-w-[280px] relative">
      <label class="input input-bordered flex items-center gap-2 w-full bg-base-100 border-base-300 focus-within:border-primary transition-all shadow-sm">
        <span class="material-symbols-outlined text-base-content/40 text-[20px]">search</span>
        <%= f.text_field :query,
                        value: params[:query],
                        placeholder: "Search goals...",
                        class: "grow h-full bg-transparent border-none focus:ring-0 text-sm",
                        onkeyup: "clearTimeout(this.delay); this.delay = setTimeout(() => this.form.submit(), 600)" %>
      </label>
    </div>

    <div class="flex flex-wrap items-center gap-4">
      <%# Category Select %>
      <div class="flex items-center gap-2">
        <div class="flex items-center justify-center border border-base-300 bg-base-100 px-3 h-[3rem] rounded-lg shadow-sm">
           <span class="material-symbols-outlined text-primary/70 text-[20px]">category</span>
        </div>
        <%= f.select :category,
                     Goal.categories.keys.map { |c| [c.titleize, c] },
                     { include_blank: "All Categories", selected: params[:category] },
                     { name: "category", class: "select select-bordered focus:outline-none min-w-[160px] border-base-300 focus:border-primary transition-all shadow-sm", onchange: "this.form.submit()" } %>
      </div>

      <%# Sort Select %>
      <div class="flex items-center gap-2">
        <div class="flex items-center justify-center border border-base-300 bg-base-100 px-3 h-[3rem] rounded-lg shadow-sm">
           <span class="material-symbols-outlined text-primary/70 text-[20px]">sort</span>
        </div>
        <%= f.select :sort,
                     [
                       ["Deadline: Soonest", "deadline_soon"],
                       ["Deadline: Furthest", "deadline_far"],
                       ["Progress: High to Low", "progress_high"],
                       ["Progress: Low to High", "progress_low"]
                     ],
                     { selected: params[:sort] || "deadline_soon" },
                     { name: "sort", class: "select select-bordered focus:outline-none min-w-[180px] border-base-300 focus:border-primary transition-all shadow-sm", onchange: "this.form.submit()" } %>
      </div>

      <%# Apply/Search Button (Optional since we have auto-submit, but good for UX) %>
      <%= f.button type: :submit, name: nil, class: "btn btn-primary px-6 shadow-lg shadow-primary/20", id: "apply-filters" do %>
        <span class="material-symbols-outlined text-[20px]">filter_list</span>
        <span class="hidden sm:inline">Filter</span>
      <% end %>

      <% if params[:category].present? || params[:sort].present? || params[:query].present? %>
        <%= link_to goals_path(tab: params[:tab]), class: "btn btn-ghost text-error gap-2 hover:bg-error/10 transition-colors" do %>
          <span class="material-symbols-outlined text-[18px]">filter_list_off</span>
          <span class="hidden sm:inline">Clear Filters</span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
