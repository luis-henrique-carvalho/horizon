<div class="nested-fields flex items-center gap-3 p-2.5 bg-base-100 border border-base-200 rounded-xl group hover:border-primary/20 hover:bg-base-200/30 transition-all" data-new-record="<%= f.object.new_record? %>">
  <%= f.hidden_field :_destroy %>

  <div class="form-control">
    <%= f.check_box :completed, class: "checkbox checkbox-xs checkbox-primary rounded border-base-300" %>
  </div>

  <div class="flex-1">
    <%= f.text_field :title, placeholder: "Subtask Name", class: "input input-ghost w-full p-0 h-auto min-h-0 text-sm text-base-content/70 focus:text-base-content focus:bg-transparent border-none focus:outline-none focus:ring-0" %>
  </div>

  <button type="button" data-action="nested-form#remove" class="btn btn-ghost btn-xs opacity-0 group-hover:opacity-100 text-base-content/40 hover:text-error transition-all btn-circle">
    <span class="material-symbols-outlined text-sm">delete</span>
  </button>
</div>
