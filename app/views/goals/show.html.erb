<div class="mb-8">
  <div class="text-sm breadcrumbs text-base-content/60">
    <ul>
      <li><%= link_to "Home", root_path, class: "hover:text-primary transition-colors" %></li>
      <li><%= link_to "Goals", goals_path, class: "hover:text-primary transition-colors" %></li>
      <li class="font-bold text-base-content"><%= @goal.title %></li>
    </ul>
  </div>

  <div class="flex flex-wrap justify-between items-end gap-6 mt-4">
    <div>
      <h1 class="text-3xl font-black tracking-tight"><%= @goal.title %></h1>
      <div class="flex items-center gap-3 mt-2">
        <span class="text-[10px] uppercase tracking-widest text-primary font-bold"><%= @goal.category.titleize %></span>
        <span class="px-2 py-1 text-[11px] font-bold rounded uppercase 
          <%= case @goal.status
              when 'on_track' then 'text-success bg-success/10'
              when 'behind' then 'text-warning bg-warning/10'
              when 'completed' then 'text-info bg-info/10'
              when 'at_risk' then 'text-error bg-error/10'
              else 'text-base-content/70 bg-base-content/10'
              end
          %>">
          <%= @goal.status.titleize %>
        </span>
      </div>
    </div>
    
    <div class="flex gap-2">
      <%= link_to edit_goal_path(@goal), class: "btn btn-outline hover:bg-base-200 hover:text-base-content border-base-300 gap-2 font-bold" do %>
        <span class="material-symbols-outlined text-[18px]">edit</span>
        Edit Goal
      <% end %>
      <%= button_to goal_path(@goal), method: :delete, form_class: "inline", class: "btn btn-outline hover:bg-error hover:text-white border-base-300 hover:border-error gap-2 font-bold" do %>
        <span class="material-symbols-outlined text-[18px]">delete</span>
        Delete
      <% end %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <div class="md:col-span-2">
    <div class="card bg-base-100 shadow-sm hover:shadow-xl transition-all border border-base-200 rounded-xl">
      <div class="card-body p-6">
        <h2 class="card-title text-xl mb-4 font-black">Description</h2>
        
        <div class="prose max-w-none text-base-content/80">
          <% if @goal.description.present? %>
            <%= simple_format @goal.description %>
          <% else %>
            <p class="text-base-content/50 italic">No description provided for this objective.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
  
  <div class="md:col-span-1 flex flex-col gap-6">
    <div class="card bg-base-100 shadow-sm hover:shadow-xl transition-all border border-base-200 rounded-xl">
      <div class="card-body p-6">
        <h2 class="card-title text-xl mb-4 font-black flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[24px]">trending_up</span>
          Progress
        </h2>
        <div class="flex justify-between items-end mb-2">
          <span class="text-sm text-base-content/60 font-medium">Tracking</span>
          <span class="text-2xl font-bold"><%= @goal.progress %>%</span>
        </div>
        <progress class="progress w-full h-3
          <%= case @goal.status
              when 'on_track' then 'progress-success'
              when 'behind' then 'progress-warning'
              when 'completed' then 'progress-info'
              when 'at_risk' then 'progress-error'
              else 'progress-primary'
              end
          %>" value="<%= @goal.progress %>" max="100"></progress>
      </div>
    </div>

    <div class="card bg-base-100 shadow-sm hover:shadow-xl transition-all border border-base-200 rounded-xl">
      <div class="card-body p-6">
        <h2 class="card-title text-xl mb-4 font-black flex items-center gap-2">
          <span class="material-symbols-outlined text-primary text-[24px]">info</span>
          Details
        </h2>
        
        <div class="flex flex-col gap-4">
          <div>
            <span class="text-[10px] text-base-content/50 uppercase font-bold block mb-1">Status</span>
            <span class="font-medium inline-flex items-center gap-2">
               <%= @goal.status.titleize %>
            </span>
          </div>
          <div class="h-[1px] w-full bg-base-200"></div>
          <div>
            <span class="text-[10px] text-base-content/50 uppercase font-bold block mb-1">Target Date</span>
            <span class="font-medium"><%= @goal.deadline&.strftime("%B %d, %Y") || "No date set" %></span>
          </div>
          <div class="h-[1px] w-full bg-base-200"></div>
          <div>
            <span class="text-[10px] text-base-content/50 uppercase font-bold block mb-1">Owner</span>
            <div class="flex items-center gap-3 mt-1">
              <div class="avatar">
                <div class="w-8 rounded-full border border-base-200">
                  <img src="https://ui-avatars.com/api/?name=<%= @goal.user.email.first(2).upcase %>&background=random" />
                </div>
              </div>
              <span class="font-medium text-sm"><%= @goal.user.email %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
