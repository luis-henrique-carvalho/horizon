<% content_for :title, "My Goals - Horizon" %>

<div class="flex flex-wrap justify-between items-end gap-6 mb-8">
  <div class="flex flex-col gap-2">
    <h1 class="text-4xl font-black leading-tight tracking-tight">My Goals</h1>
    <p class="text-base-content/70 text-base">Manage and track your strategic objectives</p>
  </div>
  <%= link_to new_goal_path, class: "btn btn-primary shadow-lg shadow-primary/20" do %>
    <span class="material-symbols-outlined">add_circle</span>
    Create New Goal
  <% end %>
</div>

<div class="flex flex-col gap-6 mb-8">
  <div class="flex items-center justify-between border-b border-base-200">
    <div class="tabs tabs-bordered">
      <a class="tab tab-active text-primary font-bold">Active Goals (<%= @goals.count %>)</a>
      <a class="tab text-base-content/60 font-medium hover:text-base-content transition-colors">Archived (0)</a>
    </div>
  </div>
  <div class="flex flex-wrap items-center gap-3">
    <div class="flex items-center gap-2 px-3 py-2 bg-base-100 border border-base-200 rounded-lg cursor-pointer hover:border-primary transition-colors">
      <span class="material-symbols-outlined text-primary text-[20px]">category</span>
      <span class="text-sm font-medium">Category: All</span>
      <span class="material-symbols-outlined text-base-content/40 text-[18px]">expand_more</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-2 bg-base-100 border border-base-200 rounded-lg cursor-pointer hover:border-primary transition-colors">
      <span class="material-symbols-outlined text-primary text-[20px]">event</span>
      <span class="text-sm font-medium">Deadline: Soonest</span>
      <span class="material-symbols-outlined text-base-content/40 text-[18px]">expand_more</span>
    </div>
    <div class="flex items-center gap-2 px-3 py-2 bg-base-100 border border-base-200 rounded-lg cursor-pointer hover:border-primary transition-colors">
      <span class="material-symbols-outlined text-primary text-[20px]">trending_up</span>
      <span class="text-sm font-medium">Progress: High to Low</span>
      <span class="material-symbols-outlined text-base-content/40 text-[18px]">expand_more</span>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% @goals.each do |goal| %>
    <% 
      status_color = case goal.status
                     when 'on_track' then 'text-success bg-success/10'
                     when 'behind' then 'text-warning bg-warning/10'
                     when 'completed' then 'text-info bg-info/10'
                     when 'at_risk' then 'text-error bg-error/10'
                     else 'text-base-content/70 bg-base-content/10'
                     end
                     
      progress_color = case goal.status
                       when 'on_track' then 'progress-success'
                       when 'behind' then 'progress-warning'
                       when 'completed' then 'progress-info'
                       when 'at_risk' then 'progress-error'
                       else 'progress-primary'
                       end
    %>
    
    <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-xl hover:border-primary/20 transition-all group rounded-xl">
      <div class="card-body p-5 flex flex-col h-full">
        <div class="flex justify-between items-start mb-4">
          <div class="flex flex-col gap-1">
            <span class="text-[10px] uppercase tracking-widest text-primary font-bold"><%= goal.category.titleize %></span>
            <h3 class="text-lg font-bold group-hover:text-primary transition-colors"><%= goal.title %></h3>
          </div>
          <span class="px-2 py-1 text-[11px] font-bold rounded uppercase <%= status_color %>"><%= goal.status.titleize %></span>
        </div>

        <div class="mb-6">
          <div class="flex justify-between items-end mb-2">
            <span class="text-xs text-base-content/60">Progress</span>
            <span class="text-sm font-bold"><%= goal.progress %>%</span>
          </div>
          <progress class="progress <%= progress_color %> w-full" value="<%= goal.progress %>" max="100"></progress>
        </div>

        <div class="flex items-center gap-4 mb-6">
          <div class="flex flex-col">
            <span class="text-[10px] text-base-content/50 uppercase font-bold">Deadline</span>
            <span class="text-sm font-medium"><%= goal.deadline&.strftime("%b %d, %Y") || "No date" %></span>
          </div>
          <div class="h-8 w-[1px] bg-base-200"></div>
          <div class="flex flex-col">
            <span class="text-[10px] text-base-content/50 uppercase font-bold">Assignee</span>
            <div class="avatar-group -space-x-2 mt-1">
              <div class="avatar border-base-100">
                <div class="w-6">
                  <img data-alt="Team member avatar placeholder" src="https://ui-avatars.com/api/?name=<%= current_user&.email&.first(2) || 'U' %>&background=random" />
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-2 mt-auto pt-4 border-t border-base-200/50">
          <%= link_to "View Details", goal, class: "flex-1 btn btn-sm bg-base-200 hover:btn-primary border-0" %>
          <%= link_to edit_goal_path(goal), class: "btn btn-sm btn-ghost hover:text-primary transition-colors px-2" do %>
            <span class="material-symbols-outlined text-[20px]">edit</span>
          <% end %>
          <%= button_to goal_path(goal), method: :delete, form_class: "inline", class: "btn btn-sm btn-ghost hover:text-error transition-colors px-2" do %>
            <span class="material-symbols-outlined text-[20px]">delete</span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# Placeholder for New Goal %>
  <%= link_to new_goal_path, class: "flex flex-col items-center justify-center bg-base-200/20 hover:bg-base-200/40 border-2 border-dashed border-base-300 rounded-xl p-8 hover:border-primary/50 transition-all cursor-pointer group h-full min-h-[300px]" do %>
    <div class="size-12 rounded-full bg-base-200 flex items-center justify-center mb-4 group-hover:bg-primary group-hover:text-white transition-all">
      <span class="material-symbols-outlined">add</span>
    </div>
    <p class="font-bold text-base-content/60 group-hover:text-base-content">Add New Goal</p>
    <p class="text-xs text-base-content/40 text-center mt-2 px-6">Define a new objective and track its key performance indicators</p>
  <% end %>
</div>

<% if @goals.empty? %>
<div class="flex items-center justify-center mt-12 mb-8">
  <div class="text-center">
    <p class="text-base-content/60 mb-2">You haven't added any goals yet.</p>
  </div>
</div>
<% else %>
<div class="flex items-center justify-center mt-12 mb-8">
  <button class="btn btn-outline border-base-300 hover:bg-base-200 text-sm font-bold px-8">
    Load More Goals
  </button>
</div>
<% end %>
