<% content_for :title, "My Goals - Horizon" %>

<div class="flex flex-wrap justify-between items-end gap-6 mb-8">
  <div class="flex flex-col gap-2">
    <h1 class="text-4xl font-black leading-tight tracking-tight">My Goals</h1>
    <p class="text-base-content/70 text-base">Manage and track your strategic objectives</p>
  </div>
  <%= link_to new_goal_path, class: "btn btn-primary shadow-lg shadow-primary/20" do %>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
    Create New Goal
  <% end %>
</div>

<% if @goals.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @goals.each do |goal| %>
      <% 
        status_color = case goal.status
                       when 'on_track' then 'badge-success'
                       when 'behind' then 'badge-warning'
                       when 'completed' then 'badge-info'
                       when 'at_risk' then 'badge-error'
                       else 'badge-ghost'
                       end
                       
        progress_color = case goal.status
                         when 'on_track' then 'progress-success'
                         when 'behind' then 'progress-warning'
                         when 'completed' then 'progress-info'
                         when 'at_risk' then 'progress-error'
                         else 'progress-primary'
                         end
      %>
      
      <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-xl hover:border-primary/30 transition-all">
        <div class="card-body p-5">
          <div class="flex justify-between items-start mb-2">
            <div class="flex flex-col gap-1">
              <span class="text-[10px] uppercase tracking-widest text-primary font-bold"><%= goal.category.titleize %></span>
              <h3 class="text-lg font-bold"><%= goal.title %></h3>
            </div>
            <span class="badge badge-sm font-bold uppercase <%= status_color %>"><%= goal.status.titleize %></span>
          </div>

          <div class="my-4">
            <div class="flex justify-between items-end mb-2">
              <span class="text-xs text-base-content/60">Progress</span>
              <span class="text-sm font-bold"><%= goal.progress %>%</span>
            </div>
            <progress class="progress <%= progress_color %> w-full" value="<%= goal.progress %>" max="100"></progress>
          </div>

          <div class="flex items-center gap-4 mt-auto mb-4">
            <div class="flex flex-col">
              <span class="text-[10px] text-base-content/60 uppercase">Deadline</span>
              <span class="text-sm font-medium"><%= goal.deadline&.strftime("%b %d, %Y") || "No date" %></span>
            </div>
          </div>

          <div class="flex items-center gap-2 mt-2 pt-4 border-t border-base-200">
            <%= link_to "View Details", goal, class: "btn btn-sm flex-1 bg-base-200 hover:btn-primary" %>
            <%= link_to edit_goal_path(goal), class: "btn btn-sm btn-square btn-ghost text-base-content/60 hover:text-primary" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.89 1.147l-2.84 1.42a.375.375 01-1.89-1.147l1.42-2.84a4.5 4.5 0 011.147-1.89L16.862 4.487m0 0l-2.32 2.32" /></svg>
            <% end %>
            <%= button_to goal_path(goal), method: :delete, form_class: "inline", class: "btn btn-sm btn-square btn-ghost text-base-content/60 hover:text-error" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col items-center justify-center p-12 bg-base-100 border-2 border-dashed border-base-300 rounded-xl text-center">
    <div class="w-16 h-16 bg-primary/10 text-primary rounded-full flex items-center justify-center mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.36 9 9 0 1112.06-12.06 6 6 0 01-3.21 2.92m-5.84 5.38v.82a2 2 0 01-2 2h-1.8a2 2 0 01-2-2zM9 11v-.82a2 2 0 012-2h1.8a2 2 0 012 2zM9 11A8 8 0 1021 8" /></svg>
    </div>
    <h3 class="text-xl font-bold mb-2">No goals yet!</h3>
    <p class="text-base-content/60 mb-6 max-w-sm">Get started by creating your first strategic objective to track progress.</p>
    <%= link_to "Create First Goal", new_goal_path, class: "btn btn-primary" %>
  </div>
<% end %>
