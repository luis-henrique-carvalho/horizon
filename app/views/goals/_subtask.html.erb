<div id="<%= dom_id subtask %>" class="flex items-center gap-4 p-3 mb-4 hover:bg-base-200/30 rounded-lg transition-colors group">
  <div class="flex-none">
    <%= form_with(model: subtask, url: subtask_path(subtask), method: :patch, data: { turbo_frame: "_top" }) do |f| %>
      <%= f.check_box :completed,
          class: "checkbox checkbox-primary checkbox-sm",
          onchange: "this.form.requestSubmit()",
          id: "subtask_#{subtask.id}_completed" %>
      <%= f.submit "Update", class: "hidden" %>
    <% end %>
  </div>
  <div class="flex-1">
    <label for="subtask_<%= subtask.id %>_completed" class="text-sm font-medium cursor-pointer <%= 'line-through text-base-content/40' if subtask.completed? %>">
      <%= subtask.title %>
    </label>
    <% if subtask.completed_at.present? %>
      <p class="text-[10px] text-base-content/30 font-bold uppercase tracking-wider">
        Done on <%= subtask.completed_at.strftime("%b %d, %H:%M") %>
      </p>
    <% end %>
  </div>
</div>
